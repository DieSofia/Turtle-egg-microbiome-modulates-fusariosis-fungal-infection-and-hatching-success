#The primer-free sequence files are now ready to be analysed through the DADA2 pipeline. Similar to the earlier steps for reading FASTQ files, we read the names of the cutadapt-ed FASTQ files and perform some string manipulation to obtain the matched lists of forward and reverse FASTQ files.

### following and adapting the pipeline for ITS https://benjjneb.github.io/dada2/ITS_workflow.html

# Forward and reverse fastq filenames have the format:
cutFs <- sort(list.files(newpath, pattern = "L001_R1_001.fastq.gz", full.names = TRUE))
cutRs <- sort(list.files(newpath, pattern = "L001_R2_001.fastq.gz", full.names = TRUE))

# Extract sample names, assuming filenames have format:
get.sample.name <- function(fname) strsplit(basename(fname), "_")[[1]][1]
sample.names <- unname(sapply(cutFs, get.sample.name))
head(sample.names)


# Let's inspect read quality profiles 

  #Forward reads
QualProf<-plotQualityProfile(cutFs[1:2])

QualProf

QualProfR<-plotQualityProfile(cutRs[1:2])

QualProfR


#Assigning the filenames for the output of the filtered reads to be stored as fastq.gz files.

filtFs <- file.path(newpath, "filtered", basename(cutFs))
filtRs <- file.path(newpath, "filtered", basename(cutRs))

library(Matrix)

out2 <- filterAndTrim(cutFs, filtFs, cutRs, filtRs, truncQ = 2, maxEE = c(5, 5), maxN = 0, minLen = 20, rm.phix = TRUE, compress = TRUE, multithread = TRUE)

### When deciding on the number of errors you allow, consider that it is not the same as for 16S and depends on the sequence quality. A DADA2-based ITS pipeline study found that maxEE values up to 8 can still perform well for fungal data. Values of c(2, 5) or c(5, 5) are widely used in practice. https://pmc.ncbi.nlm.nih.gov/articles/PMC8765055/

out2<-data.frame(out2)


#Learning error rates

errF <- learnErrors(filtFs, multithread = TRUE)


errR <- learnErrors(filtRs, multithread = TRUE)


plotErrors(errF, nominalQ = TRUE)



head(sample.names)

## check which samples are still there
existsF <- file.exists(filtFs)
existsR <- file.exists(filtRs)


derepFs <- derepFastq(filtFs[existsF], verbose=TRUE)

derepRs <- derepFastq(filtRs[existsR], verbose=TRUE)

names(derepFs) <- sample.names[existsF]
names(derepRs) <- sample.names[existsR]


dadaFs <- dada(derepFs, err = errF, multithread = TRUE)
dadaRs <- dada(derepRs, err = errR, multithread = TRUE)


##### just concatenate
mergers <- mergePairs(dadaFs, derepFs, dadaRs, derepRs, maxMismatch = 3, verbose = TRUE, minOverlap = 12, returnRejects = FALSE, justConcatenate = TRUE, trimOverhang = TRUE)

head(mergers)


seqtab <- makeSequenceTable(mergers)
dim(seqtab)
