################### BUILD THE TAXONOMICAL CLASIFIER#######

#getting the NCBI data through the plugin of R script 

qiime rescript get-ncbi-data \
    --p-query 'elongation factor 1-alpha[All Fields] AND fungi[filter]'\
    --o-sequences ncbi-refseqs-unfilteredfungi.qza \
    --o-taxonomy ncbi-refseqs-taxonomy-unfilteredfungi.qza \
    --p-n-jobs 30


qiime rescript filter-seqs-length-by-taxon \
    --i-sequences ncbi-refseqs-unfilteredfungi.qza \
    --i-taxonomy ncbi-refseqs-taxonomy-unfilteredfungi.qza \
    --p-labels Eukarya Fungi \
    --p-min-lens 100 1200 \
    --o-filtered-seqs ncbi-refseqsfungi.qza \
    --o-discarded-seqs ncbi-refseqs-tooshortfungi.qza



qiime rescript filter-taxa \
    --i-taxonomy ncbi-refseqs-taxonomy-unfilteredfungi.qza \
    --m-ids-to-keep-file ncbi-refseqsfungi.qza \
    --o-filtered-taxonomy ncbi-refseqs-taxonomyfungi.qza




##Now we need to "train" the database, which basically extracting the TEF (EFalpha 1) region of interest using the primers that we used to amplify our amplicon#

qiime feature-classifier extract-reads \
--i-sequences ncbi-refseqsfungi.qza \
--p-f-primer CCGGTCACTTGATCTACCAG \
--p-r-primer ATGACGGTGACATAGTAGCG \
--p-n-jobs 30 \
--p-read-orientation 'both' \
--o-reads ncbi-specific-ref-seqs.qza


qiime feature-classifier fit-classifier-naive-bayes \
--i-reference-reads ncbi-specific-ref-seqs.qza \
--i-reference-taxonomy ncbi-refseqs-taxonomyfungi.qza \
--o-classifier ncbi-refseqs-classifierfungi.qza


#### Now we apply our classifier created with rScript within our sequences to obtain the taxonomy


qiime feature-classifier classify-sklearn \
  --i-classifier /ncbi-refseqs-classifierfungi.qza \
  --i-reads /QIIMEout/rep-seqs-dada2.qza \
  --p-n-jobs 30 \
  --o-classification /QIIMEout/taxonomyfungi.qza


