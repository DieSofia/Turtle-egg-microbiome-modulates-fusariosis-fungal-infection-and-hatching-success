tmux


###open qiime2
conda activate qiime2




cd yourpath

qiime tools import \
  --type 'SampleData[PairedEndSequencesWithQuality]' \
  --input-path yourpath\
  --input-format CasavaOneEightSingleLanePerSampleDirFmt  \
  --output-path demux-paired-end.qza


qiime cutadapt trim-paired \
--i-demultiplexed-sequences demux-paired-end.qza \
--p-front-f NNNNGTGCCAGCMGCCGCGGTAA \
--p-front-r GGACTACHVGGGTWTCTAAT \
--p-error-rate .1 \
--p-indels \
--p-match-read-wildcards \
--p-discard-untrimmed \
--o-trimmed-sequences run_16Strimmed.qza \
--verbose



qiime demux summarize \
    --i-data run_16Strimmed.qza \
    --p-n 100000 \
    --o-visualization run_16Strimmed.qzv

qiime tools view run_16Strimmed.qzv


mkdir QIIMEout

qiime dada2 denoise-paired \
--i-demultiplexed-seqs run_16Strimmed.qza \
--p-n-threads 32 \
--p-trunc-len-f 200 \
--p-trunc-len-r 200 \
--p-max-ee-f 2 \
--p-max-ee-r 2 \
--p-chimera-method pooled \
--o-table /QIIMEout/table-dada2.qza \
--o-representative-sequences /QIIMEout/rep-seqs-dada2.qza \
--o-denoising-stats /QIIMEout/DADA2stats.qza \
--verbose


#This code allows us to visualise the ASV sequences kept in the dataset:

qiime feature-table tabulate-seqs \
  --i-data /QIIMEout/rep-seqs-dada2.qza \
  --o-visualization /QIIMEout/rep-seqs-dada2.qzv


qiime tools view /QIIMEout/rep-seqs-dada2.qzv



qiime feature-table summarize \
--i-table /QIIMEout/table-dada22.qza \
--o-visualization /QIIMEout/table-dada2.qzv \
--m-sample-metadata-file Metadata_16S.csv


qiime tools view /QIIMEout/table-dada2.qzv


#Ok we are going to assign taxonomy to our sequences: 

#We’ll do that using a database called SILVA. We selected sequences that correspond to the region we amplified in our PCR: i.e. the sequences in the database have been trimmed to only include 250 bases from the region of the 16S that was sequenced in this analysis (the V4 region, bound by the 515F/806R primer pair). We’ll apply this classifier to our sequences, and we can generate a visualization of the resulting mapping from sequence to taxonomy.

#We can do this using the database below:

qiime feature-classifier classify-sklearn \
  --i-classifier silva.132.V4.515.806.7_levels.classifier.qza \
  --i-reads /QIIMEout/rep-seqs-dada22.qza \
  --p-n-jobs 30 \
  --o-classification /QIIMEout/taxonomy.qza



#lets visualise our taxonmic assingment of our sequences!

qiime metadata tabulate \
  --m-input-file /QIIMEout/taxonomy.qza \
  --o-visualization/QIIMEout/taxonomy.qzv


qiime tools view /QIIMEout/taxonomy.qzv


#lets visualise our results as a barplot:

qiime taxa barplot \
  --i-table QIIMEout/table-dada2.qza \
  --i-taxonomy QIIMEout/taxonomy.qza \
  --m-metadata-file Metadata_16S.csv \
  --o-visualization QIIMEout/taxa-bar-plots.qzv

qiime tools view QIIMEout/taxa-bar-plots.qzv

###lets remove sequences that are Archaea,mitochondra,chloroplast,Unassigned and not assigned at the phylum level from our table and list of sequences:

qiime taxa filter-table \
  --i-table QIIMEout/table-dada2.qza  \
  --i-taxonomy QIIMEout/taxonomy.qza \
  --p-exclude Archaea,mitochondra,chloroplast,Unassigned \
  --p-include D_1__ \
  --o-filtered-table QIIMEout/table-filtered.qza



qiime taxa filter-seqs \
  --i-sequences QIIMEout/rep-seqs-dada22.qza \
  --i-taxonomy QIIMEout/taxonomy.qza \
  --p-exclude Archaea,mitochondra,chloroplast,Unassigned \
  --p-include D_1__ \
  --o-filtered-sequences QIIMEout/rep-seqs-filtered.qza


qiime feature-table tabulate-seqs \
  --i-data QIIMEout/rep-seqs-filtered.qza \
