### Extract the information of the alpha diversity and betadispersion from the bacteriome and mycobiome and create a new table to run these analyses.
PredictInf <- read.csv("AlphaBetaMicroFungi_Table.csv")

# ==============================================================================
# 1.  INFECTION PREVALENCE ~ DIVERSITY  (FSSCInf ~ binomial GLMM)
# ==============================================================================

# ── 1.1  Selected model: FSSCInf ~ ITS Shannon + (1|NestID) ──────────────────
## null model
glmmTMB.null <- glmmTMB(FSSCInf ~ 1 + (1|NestID), family = "binomial", data = PredictInf, na.action = na.fail)


# *** Figure 2a ***

glmmTMB1.3 <- glmmTMB(FSSCInf ~ scale(diversity_shannon) + (1|NestID), family = "binomial", data = PredictInf, na.action = na.fail)
summary(glmmTMB1.3)
confint(glmmTMB1.3)
anova(glmmTMB1.3,glmmTMB.null)

(FSSC_infection_shannon.3 <- ggpredict(glmmTMB1.3, terms = "diversity_shannon [all]") %>% plot() + theme_classic(14) + xlab("Bacteriome Shannon diversity") + ylab("FSSC infection probability") + ggtitle("") + geom_point(data = PredictInf, aes(x = diversity_shannon, y = FSSCInf), position = position_jitter(seed = 100, height = 0.025)))

# *** Figure 2c *** Only significant model
glmmTMB1.4 <- glmmTMB(FSSCInf ~ scale(diversity_shannon2) + (1|NestID), family = "binomial", data = PredictInf, na.action = na.fail)
summary(glmmTMB1.4)
confint(glmmTMB1.4)
anova(glmmTMB1.4,glmmTMB.null)

(FSSC_infection_shannon2.4 <- ggpredict(glmmTMB1.4, terms = "diversity_shannon2 [all]") %>% plot(colors = "red")+ theme_classic(14) + xlab("Mycobiome Shannon diversity") + ylab("FSSC infection probability") + ggtitle("") + geom_point(data = PredictInf, aes(x = diversity_shannon2, y = FSSCInf), position = position_jitter(seed = 100, height = 0.025)))


