# ==============================================================================
# 3.  HATCHING SUCCESS ~ DIVERSITY  (numStage ~ binomial GLM)
# NestID random effect explains negligible variance; GLM used (see methods).
# ==============================================================================

# ── 3.1  Modelling: Developmental stage ~ FSSC infection and Diversity  (Figure 5) ───────────────────────────

### null model
MH.null <- glmer(numStage ~ FSSC2 + (1|NestID), family = "binomial", data = PredictInf, na.action =  na.fail)

#### selected models 
# 16S observed
M1H.glmm.1 <- glmer(numStage ~ FSSC2 + scale(observed) + (1|NestID), family = "binomial", data = PredictInf, na.action =  na.fail)

anova(M1H.glmm.1,MH.null)

# ITSS observed
M2H.glmm.1 <- glmer(numStage ~ FSSC2 + scale(Observed2) + (1|NestID), family = "binomial", data = PredictInf, na.action =  na.fail, control = glmerControl(optimizer ='optimx', optCtrl=list(method='L-BFGS-B')))

anova(M2H.glmm.1,MH.null)

# 16S Shannon
M3H.glmm.1 <- glmer(numStage ~ FSSC2 + scale(diversity_shannon) + (1|NestID), family = "binomial", data = PredictInf, na.action =  na.fail)

anova(M3H.glmm.1,MH.null)

# ITS Shannon
M4H.glmm.1 <- glmer(numStage ~ FSSC2 + scale(diversity_shannon2) + (1|NestID), family = "binomial", data = PredictInf, na.action =  na.fail)

anova(M4H.glmm.1,MH.null)

# 16S Betadispersion
M5H.glmm.1 <- glmer(numStage ~ FSSC2 + scale(betadist) + (1|NestID), family = "binomial", data = PredictInf, na.action =  na.fail)

anova(M5H.glmm.1,MH.null)

# ITS Betadispersion
M6H.glmm.1 <- glmer(numStage ~ FSSC2 + scale(betadist1) + (1|NestID), family = "binomial", data = PredictInf, na.action =  na.fail, control = glmerControl(optimizer ='optimx', optCtrl=list(method='L-BFGS-B')))

anova(M6H.glmm.1,MH.null)

## All the diversity metrics are significant with probability of hatching, only betadist1 (mycobiome beta diversity) is not significant.

(g1 <- ggpredict(M1H.glmm.1, terms = c("observed [all]","FSSC2")) %>% plot(show_data = TRUE, jitter = c(0,0.025), dot_alpha = 1) + theme_classic(14) + xlab("Bacteriome species richness") + ylab("Hatchability") + ggtitle("") + scale_colour_manual(values= co_jo ,name="Fusariosis", breaks=c("PCR(-)/NoFSSC","FSSC_Infected"),labels=c("Uninfected","Infected")) + scale_fill_manual(values=co_jo,name="Fusariosis", breaks=c("PCR(-)/NoFSSC","FSSC_Infected"),labels=c("Uninfected","Infected"))) 

