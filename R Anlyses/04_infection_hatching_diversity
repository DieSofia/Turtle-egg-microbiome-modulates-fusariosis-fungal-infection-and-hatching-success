(g3 <- ggpredict(M3H.glmm.1, terms = c("diversity_shannon [all]","FSSC2")) %>% plot(show_data = TRUE, jitter = c(0,0.025), dot_alpha = 1) + theme_classic(14) + xlab("Bacteriome Shannon diversity") + ylab("Hatchability") + ggtitle("") + scale_colour_manual(values= co_jo ,name="Fusariosis", breaks=c("PCR(-)/NoFSSC","FSSC_Infected"),labels=c("Uninfected","Infected")) + scale_fill_manual(values=co_jo,name="Fusariosis", breaks=c("PCR(-)/NoFSSC","FSSC_Infected"),labels=c("Uninfected","Infected"))) 

