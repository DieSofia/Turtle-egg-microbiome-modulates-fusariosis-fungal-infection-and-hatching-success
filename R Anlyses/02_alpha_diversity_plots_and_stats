# =============================================================================
# 02_alpha_diversity.R
#
# PURPOSE: Visualise and model alpha diversity (species richness, Shannon)
#          of egg bacteriome (16S) and mycobiome (ITS) as a function of
#          hatching stage and FSSC infection status.
#
# INPUT:
#          Micro_EGG_alfa.rds 
#          Fungi_EGG_alfa.rds  
#
# OUTPUT:
#   figures/AlphaAllEggsFSSC.png — 2x2 panel figure (manuscript Fig. 1)
# =============================================================================

source("R/00_setup.R")

set.seed(42)

# =============================================================================
# SECTION 1: Load data
# =============================================================================

Micro_EGG_alfa <- readRDS("Micro_EGG_alfa.rds")
Fungi_EGG_alfa <- readRDS("Fungi_EGG_alfa.rds")

# Axis label lookup (used in all plots)
stage_labels <- c(
  "UnhatchedEggED" = "Failed E.D.\negg",
  "UnhatchedEggLD" = "Failed L.D.\negg",
  "HatchedEgg"     = "Hatched\negg"
)

my_comparisons <- list(
  c("UnhatchedEggLD", "UnhatchedEggED"),
  c("HatchedEgg",     "UnhatchedEggED"),
  c("HatchedEgg",     "UnhatchedEggLD")
)

# =============================================================================
# SECTION 2: Species richness (Observed) — Bacteriome
# =============================================================================

## 2.1 Plot -------------------------------------------------------------------
Micro3Egg <- ggplot(Micro_EGG_alfa, aes(x = Stage, y = observed)) +
  geom_boxplot(outlier.shape = NA, aes(fill = FSSC2)) +
  geom_jitter(colour = "black", position = position_dodge(0.75),
              size = 1.5, aes(fill = FSSC2)) +
  scale_x_discrete(labels = stage_labels) +
  scale_fill_manual(labels = c("Uninfected", "Infected"), values = cojo) +
  xlab(" ") +
  ylab("Species Richness\nBacteriome") +
  guides(
    fill  = guide_legend(title = "Fusariosis", reverse = FALSE,
                         keywith = 1, keyheight = 1),
    shape = guide_legend(title = waiver(), reverse = TRUE,
                         keywith = 1, keyheight = 1)
  ) +
  theme_linedraw() +
  theme(
    legend.title = element_text(size = 16),
    legend.text  = element_text(size = 16),
    strip.text.x = element_text(size = 16),
    axis.text    = element_text(size = 14),
    axis.title   = element_text(size = 16),
    panel.grid.minor = element_line(linewidth = 0.05),
    panel.grid.major = element_line(linewidth = 0.05)
  )


## 2.2 Model: Observed ~ Stage + FSSC2 (negative binomial) -------------------
M1Inf_add  <- glm.nb(observed ~ Stage + FSSC2, data = Micro_EGG_alfa,
                     na.action = na.fail)
M1Inf_int  <- glm.nb(observed ~ Stage * FSSC2, data = Micro_EGG_alfa,
                     na.action = na.fail)

# Model selection
AIC(M1Inf_add, M1Inf_int)
anova(M1Inf_add, M1Inf_int)      # interaction not supported → use additive
dredge(M1Inf_add, extra = "adjR^2")
anova(M1Inf_add, test = "Chisq")

# Post-hoc Tukey contrasts
summary(glht(M1Inf_add, mcp(Stage = "Tukey")))
summary(glht(M1Inf_add, mcp(FSSC2 = "Tukey")))


## 2.3 Add significance brackets to plot -------------------------------------
Micro3Egg <- Micro3Egg +
  geom_signif(
    stat = "identity",
    data = data.frame(
      x          = c(0.7, 1.7, 2.7),
      xend       = c(1.3, 2.3, 3.3),
      y          = c(260, 260, 260),
      annotation = c("NS", "NS", "NS")
    ),
    aes(x = x, xend = xend, y = y, yend = y,
        annotation = annotation, group = annotation)
  ) +
  geom_signif(
    comparisons        = my_comparisons,
    map_signif_level   = TRUE,
    y_position         = c(280, 300, 320),
    annotation         = c("*", "***", ".")
  )


# =============================================================================
# SECTION 3: Species richness (Observed) — Mycobiome
# =============================================================================

## 3.1 Plot -------------------------------------------------------------------
Fungi3Egg <- ggplot(Fungi_EGG_alfa, aes(x = Stage, y = observed)) +
