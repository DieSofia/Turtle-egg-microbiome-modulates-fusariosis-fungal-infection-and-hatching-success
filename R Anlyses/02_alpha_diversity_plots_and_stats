## 3.2 Model: Observed ~ FSSC2 + Stage (negative binomial) ------------------
FM1Inf_add <- glm.nb(observed ~ FSSC2 + Stage, data = Fungi_EGG_alfa,
                     na.action = na.fail)
FM1Inf_int <- glm.nb(observed ~ FSSC2 * Stage, data = Fungi_EGG_alfa,
                     na.action = na.fail)

AIC(FM1Inf_add, FM1Inf_int)
anova(FM1Inf_int)                # test interaction
dredge(FM1Inf_add, extra = "adjR^2")
anova(FM1Inf_add)

summary(glht(FM1Inf_add, mcp(Stage = "Tukey")))
summary(glht(FM1Inf_add, mcp(FSSC2 = "Tukey")))


## 3.3 Add significance brackets ---------------------------------------------
Fungi3Egg <- Fungi3Egg +
  geom_signif(
    stat = "identity",
    data = data.frame(
      x          = c(0.7, 1.7, 2.7),
      xend       = c(1.3, 2.3, 3.3),
      y          = c(41, 41, 41),
      annotation = c("NS", "NS", "NS")
    ),
    aes(x = x, xend = xend, y = y, yend = y,
        annotation = annotation, group = annotation)
  ) +
  geom_signif(
    comparisons      = my_comparisons,
    map_signif_level = TRUE,
    y_position       = c(45, 51, 57),
    annotation       = c("NS", "*", "*")
  )

# =============================================================================
# SECTION 4: Shannon diversity — Bacteriome
# =============================================================================

## 4.1 Plot -------------------------------------------------------------------
Micro4Egg <- ggplot(Micro_EGG_alfa, aes(x = Stage, y = diversity_shannon)) +
  geom_boxplot(outlier.shape = NA, aes(fill = FSSC2)) +
  geom_jitter(colour = "black", position = position_dodge(0.75),
              size = 1.5, aes(fill = FSSC2)) +
  scale_x_discrete(labels = stage_labels) +
  scale_fill_manual(labels = c("Uninfected", "Infected"), values = cojo) +
  xlab(" ") +
  ylab("Shannon diversity\nBacteriome\n") +
  guides(
    fill  = guide_legend(title = "Fusariosis", reverse = FALSE,
                         keywith = 1, keyheight = 1),
    shape = guide_legend(title = waiver(), reverse = TRUE,
                         keywith = 1, keyheight = 1)
  ) +
  theme_linedraw() +
  theme(
    legend.title = element_text(size = 16),
    legend.text  = element_text(size = 16),
    strip.text.x = element_text(size = 16),
    axis.text    = element_text(size = 14),
    axis.title   = element_text(size = 16),
    panel.grid.minor = element_line(linewidth = 0.05),
    panel.grid.major = element_line(linewidth = 0.05)
  )

## 4.3 Model: Shannon ~ Stage + FSSC2 (Gamma GLM) ----------------------------
M1Inf_sh_add <- glm(diversity_shannon ~ Stage + FSSC2,
                    data = Micro_EGG_alfa, na.action = na.fail,
                    family = Gamma(identity))
M2Inf_sh_int <- glm(diversity_shannon ~ Stage * FSSC2,
                    data = Micro_EGG_alfa, na.action = na.fail,
                    family = Gamma(identity))

AIC(M1Inf_sh_add, M2Inf_sh_int)
dredge(M1Inf_sh_add, extra = "adjR^2")
anova(M1Inf_sh_add, test = "Chisq")

summary(glht(M1Inf_sh_add, mcp(Stage = "Tukey")))
summary(glht(M1Inf_sh_add, mcp(FSSC2 = "Tukey")))

## 4.2 Add significance brackets ---------------------------------------------
Micro4Egg <- Micro4Egg +
  geom_signif(
    stat = "identity",
    data = data.frame(
      x          = c(0.7, 1.7, 2.7),
      xend       = c(1.3, 2.3, 3.3),
      y          = c(4.2, 4.2, 4.2),
      annotation = c("NS", "NS", "NS")
    ),
    aes(x = x, xend = xend, y = y, yend = y,
        annotation = annotation, group = annotation)
  ) +
  geom_signif(
    comparisons      = my_comparisons,
    map_signif_level = TRUE,
    y_position       = c(4.4, 4.8, 5.2),
    annotation       = c(".", "***", "NS")
  )


# =============================================================================
# SECTION 5: Shannon diversity — Mycobiome
# =============================================================================

## 5.1 Plot -------------------------------------------------------------------
Fungi4Egg <- ggplot(Fungi_EGG_alfa, aes(x = Stage, y = diversity_shannon)) +
  geom_boxplot(outlier.shape = NA, aes(fill = FSSC2)) +
  geom_jitter(colour = "black", position = position_dodge(0.75),
              size = 1.5, aes(fill = FSSC2)) +
  scale_x_discrete(labels = stage_labels) +
  scale_fill_manual(labels = c("Uninfected", "Infected"), values = cojo) +
  xlab(" ") +
  ylab("Shannon diversity\nMycobiome\n") +
  guides(
    fill  = guide_legend(title = "Fusariosis", reverse = FALSE,
                         keywith = 1, keyheight = 1),
    shape = guide_legend(title = waiver(), reverse = TRUE,
                         keywith = 1, keyheight = 1)
  ) +
  theme_linedraw() +
  theme(
    legend.title = element_text(size = 16),
    legend.text  = element_text(size = 16),
    strip.text.x = element_text(size = 16),
    axis.text    = element_text(size = 14),
    axis.title   = element_text(size = 16),
    panel.grid.minor = element_line(linewidth = 0.05),
    panel.grid.major = element_line(linewidth = 0.05)
  )

## 5.2 Model: Shannon ~ Stage + FSSC2 (zero-inflated Gamma GLMM) -------------
# Using glmmTMB because ITS Shannon contains structural zeros
FM5Inf_sh_add <- glmmTMB(
  diversity_shannon ~ Stage + FSSC2,
  family     = ziGamma(link = "log"),
  ziformula  = ~1,
  data       = Fungi_EGG_alfa,
  na.action  = na.fail
)
FM5Inf_sh_int <- glmmTMB(
  diversity_shannon ~ Stage * FSSC2 + SeqDepth,
  family     = ziGamma(link = "log"),
  ziformula  = ~1,
  data       = Fungi_EGG_alfa,
  na.action  = na.fail
)

AIC(FM5Inf_sh_add, FM5Inf_sh_int)
# Interaction term not supported; none of the variables improve on additive model
dredge(FM5Inf_sh_add)
summary(FM5Inf_sh_add)

summary(glht(FM5Inf_sh_add, mcp(Stage = "Tukey")))
summary(glht(FM5Inf_sh_add, mcp(FSSC2 = "Tukey")))


## 5.3 Add significance brackets ---------------------------------------------
Fungi4Egg <- Fungi4Egg +
  geom_signif(
    stat = "identity",
    data = data.frame(
      x          = c(0.7, 1.7, 2.7),
      xend       = c(1.3, 2.3, 3.3),
      y          = c(4.2, 4.2, 4.2),
      annotation = c("NS", "NS", "NS")
    ),
    aes(x = x, xend = xend, y = y, yend = y,
        annotation = annotation, group = annotation)
  ) +
  geom_signif(
    comparisons      = my_comparisons,
    map_signif_level = TRUE,
    y_position       = c(4.4, 4.8, 5.2),
    annotation       = c("NS", "NS", "NS")
  )



# =============================================================================
