se_FungiUnHaEgg <- vector(mode="double", length=n_otu)
confintLower_FungiUnHaEgg <-vector(mode="double", length=n_otu)
confintUpper_FungiUnHaEgg <-vector(mode="double", length=n_otu)


#run the anova on each OTU
for(ii in 1:(n_otu)){
  #define the summary anova function:
  command <- paste("fValTest <- summary(aov( formula=",otu_ids[ii], " ~ Stage2 + FSSC2, data = phylo_comp))")
  #call the summary anova function
  eval(parse(text=command))
  #extract the f values from the anova and store it in the vector
  fValues[ii] <- fValTest[[1]]$F[1]
  #define the anova function:
  pValues[ii] <- fValTest[[1]]$P[1]
  command2 <- paste("parameters.se <- aov( formula=",otu_ids[ii], "  ~ Stage2 + FSSC2, data = phylo_comp)")
  #call the anova function
  eval(parse(text=command2))
  #extract the parameter estimates and standard errors from the anova and store it in the vector
  est_FungiUnHaEgg[ii] <- coef(summary.lm(parameters.se))[2]
  se_FungiUnHaEgg[ii] <- coef(summary.lm(parameters.se))[5]
  confintLower_FungiUnHaEgg[ii] <- confint(parameters.se)[2]
  confintUpper_FungiUnHaEgg[ii] <- confint(parameters.se)[5]
}


