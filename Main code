############# ALPHA DIVERSITY STATS


##### Single diversity metric per model#####

#### with interaction term

B1_obs <- glm.nb(observed~FSSC2*Stage,data=Micro_EGG_alfa, na.action = na.fail)

B1_sh <- glm(diversity_shannon~Stage*FSSC2, data=Micro_EGG_alfa,na.action=na.fail, family= Gamma(identity))

F1_obs <- glm.nb(observed~FSSC2*Stage,data=Fungi_EGG_alfa, na.action = na.fail)

F1_sh <- glmmTMB(diversity_shannon~Stage*FSSC2, family=ziGamma(link="log"), ziformula=~1, data= Fungi_EGG_alfa, na.action=na.fail)


#### without the interaction term

B2_obs <- glm.nb(observed~FSSC2+Stage,data=Micro_EGG_alfa, na.action = na.fail)

B2_sh <- glm(diversity_shannon~FSSC2+Stage, data=Micro_EGG_alfa,na.action=na.fail, family= Gamma(identity))

F2_obs <- glm.nb(observed~FSSC2+Stage,data=Fungi_EGG_alfa, na.action = na.fail)

F2_sh <- glmmTMB(diversity_shannon~FSSC2+Stage, family=ziGamma(link="log"), ziformula=~1, data= Fungi_EGG_alfa, na.action=na.fail)


#### developmental stage as a single variable 

B3_obs <- glm.nb(observed~Stage,data=Micro_EGG_alfa, na.action = na.fail)

B3_sh <- glm(diversity_shannon~Stage, data=Micro_EGG_alfa,na.action=na.fail, family= Gamma(identity))

F3_obs <- glm.nb(observed~Stage,data=Fungi_EGG_alfa, na.action = na.fail)

F3_sh <- glmmTMB(diversity_shannon~Stage, family=ziGamma(link="log"), ziformula=~1, data= Fungi_EGG_alfa, na.action=na.fail)


### model comparison to report the effect of infection with the interaction term FSSC

anova(B1_obs,B3_obs)
MuMIn::AICc(B1_obs,B3_obs)
anova(B1_sh,B3_sh)
MuMIn::AICc(B1_sh,B3_sh)
anova(F1_obs,F3_obs)
MuMIn::AICc(F1_obs,F3_obs)
anova(F1_sh,F3_sh)
MuMIn::AICc(F1_sh,F3_sh)



### model comparison to report the effect of infection without the interaction term FSSC

anova(B2_obs,B3_obs)
MuMIn::AICc(B2_obs,B3_obs)
anova(B2_sh,B3_sh)
MuMIn::AICc(B2_sh,B3_sh)
anova(F2_obs,F3_obs)
MuMIn::AICc(F2_obs,F3_obs)
anova(F2_sh,F3_sh)
MuMIn::AICc(F2_sh,F3_sh)


#### fusariosis infection status as a single variable 

B4_obs <- glm.nb(observed~FSSC2,data=Micro_EGG_alfa, na.action = na.fail)

B4_sh <- glm(diversity_shannon~FSSC2, data=Micro_EGG_alfa,na.action=na.fail, family= Gamma(identity))

F4_obs <- glm.nb(observed~FSSC2,data=Fungi_EGG_alfa, na.action = na.fail)

F4_sh <- glmmTMB(diversity_shannon~FSSC2, family=ziGamma(link="log"), ziformula=~1, data= Fungi_EGG_alfa, na.action=na.fail)



###### model comparison to report the effect of development

anova(B2_obs,B4_obs)
MuMIn::AICc(B2_obs,B4_obs)
anova(B2_sh,B4_sh, test= "F")
MuMIn::AICc(B2_sh,B4_sh)
anova(F2_obs,F4_obs)
MuMIn::AICc(F2_obs,F4_obs)
anova(F2_sh,F4_sh)
MuMIn::AICc(F2_sh,F4_sh)




